# development | production | test
APP_ENV=development

# 本地默认用 SQLite 即可跑通全流程；生产切换为 PostgreSQL 异步驱动
DATABASE_URL=sqlite+aiosqlite:///./app.db
# DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/trpg

# 是否开启 /docs /redoc /openapi.json，本地开发默认开启
ENABLE_DOCS=true

LOG_LEVEL=INFO

# JSON 数组格式
CORS_ORIGINS=["http://localhost:9877"]

# 不配则 AI 主持人叙事回退到确定性占位文案（CI/e2e 默认如此）；配了走真实 DeepSeek
# DEEPSEEK_API_KEY=
