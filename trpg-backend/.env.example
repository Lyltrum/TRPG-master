# development | production | test
APP_ENV=development

# 本地默认用 SQLite 即可跑通全流程；生产切换为 PostgreSQL 异步驱动
DATABASE_URL=sqlite+aiosqlite:///./app.db
# DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/trpg

# 是否开启 /docs /redoc /openapi.json，本地开发默认开启
ENABLE_DOCS=true

LOG_LEVEL=INFO

# JSON 数组格式
CORS_ORIGINS=["http://localhost:9877"]

# 不配则 AI 主持人叙事回退到确定性占位文案（CI/e2e 默认如此）；配了走真实 DeepSeek
# DEEPSEEK_API_KEY=

# ── keeper agent 实验（feat/keeper-agent 分支）──
# 结构化剧本 JSON 的路径（相对 trpg-backend 目录）。与 DEEPSEEK_API_KEY 同时
# 配置时，AI 主持人切换为真正的守秘人 agent（掷骰/角色卡/剧本/状态/HP/San
# 六工具）。剧本文件因版权 gitignore，需本地自备。
# KEEPER_MODULE_PATH=../模组资料/追书人.structured.json
# keeper 一轮回应含多跳工具调用（30-90s），锁超时建议放宽到 180
# ACTION_LOCK_TIMEOUT_SECONDS=180
